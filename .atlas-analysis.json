  "keyFeatures": [
    "Lightweight (~1000 LOC) Patricia Radix trie router",
    "100% compatible with net/http standard library",
    "No external dependencies",
    "Composable middleware stack using standard net/http middleware handlers",
    "Context-based URL parameter storage via Go's context package",
    "Route grouping, subrouters, and handler mounting",
    "Inline middleware with .With()",
    "Built-in middleware package with 25+ production-ready handlers",
    "Regex URL pattern support",
    "Wildcard and named URL parameters"
  ],
  "publicApiSurface": [
    "chi.NewRouter() *Mux",
    "chi.NewMux() *Mux",
    "chi.URLParam(r *http.Request, key string) string",
    "chi.URLParamFromCtx(ctx context.Context, key string) string",
