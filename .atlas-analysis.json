    "Router.Handle(pattern string, h http.Handler)",
    "Router.HandleFunc(pattern string, h http.HandlerFunc)",
    "Router.Method(method, pattern string, h http.Handler)",
    "Router.Get / Post / Put / Delete / Patch / Options / Head / Connect / Trace",
    "Router.NotFound(h http.HandlerFunc)",
    "Router.MethodNotAllowed(h http.HandlerFunc)",
    "Routes.Routes() []Route",
